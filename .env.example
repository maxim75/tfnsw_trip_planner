# Copy this file to .env and fill in your key. The .env file is gitignored.
# Used by the live integration tests (tests/test_vehicle_positions_live.py).
#
# Get a key from https://opendata.transport.nsw.gov.au/data/user/register and
# enable the "Trip Planner" and "Public Transport – Realtime Vehicle Positions"
# products on your application.
TFNSW_API_KEY=your_api_key_here

